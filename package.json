{
  "name": "shllshockd-ui",
  "version": "1.0.0",
  "description": "Windows commands for people who have work to do",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Agyeman Enterprises",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.7",
    "@tailwindcss/vite": "^4.1.7",
    "vite": "^5.4.19",
    "wait-on": "^9.0.10",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "package.json": [
      "npm audit --audit-level=high"
    ]
  }
}